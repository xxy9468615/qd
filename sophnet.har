[
  {
    "comment": "获取用户信息",
    "request": {
      "method": "GET",
      "url": "https://sophnet.com/api/sys/user/me",
      "headers": [
        {"name": "Accept", "value": "application/json, text/plain, */*"},
        {"name": "User-Agent", "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/150.0.0.0 Safari/537.36"},
        {"name": "Authorization", "value": "Bearer {{access_token}}"},
        {"name": "Referer", "value": "https://sophnet.com/organization/welfare"},
        {"name": "X-Requested-With", "value": "XMLHttpRequest"}
      ],
      "cookies": [
        {"name": "_c_WBKFRo", "value": "{{_c_WBKFRo}}"},
        {"name": "Hm_lvt_70c35e2a4eaa61e3234d43ac7a305148", "value": "{{Hm_lvt}}"},
        {"name": "HMACCOUNT", "value": "{{HMACCOUNT}}"},
        {"name": "acw_tc", "value": "{{acw_tc}}"},
        {"name": "authorized-token", "value": "{{authorized_token}}"},
        {"name": "multiple-tabs", "value": "{{multiple_tabs}}"},
        {"name": "Hm_lpvt_70c35e2a4eaa61e3234d43ac7a305148", "value": "{{Hm_lpvt}}"}
      ],
      "data": "",
      "mimeType": ""
    },
    "rule": {
      "success_asserts": [
        {"re": "200", "from": "status"}
      ],
      "failed_asserts": [],
      "extract_variables": [
        {"name": "user_name", "re": "\"name\":\"([^\"]+)\"", "from": "content"},
        {"name": "__log__", "re": "\"message\":\"([^\"]+)\"", "from": "content"}
      ]
    }
  },
  {
    "comment": "签到状态",
    "request": {
      "method": "GET",
      "url": "https://sophnet.com/api/sys/checkin/welfare",
      "headers": [
        {"name": "Accept", "value": "application/json, text/plain, */*"},
        {"name": "User-Agent", "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/150.0.0.0 Safari/537.36"},
        {"name": "Authorization", "value": "Bearer {{access_token}}"},
        {"name": "Referer", "value": "https://sophnet.com/organization/welfare"},
        {"name": "X-Requested-With", "value": "XMLHttpRequest"}
      ],
      "cookies": [
        {"name": "_c_WBKFRo", "value": "{{_c_WBKFRo}}"},
        {"name": "Hm_lvt_70c35e2a4eaa61e3234d43ac7a305148", "value": "{{Hm_lvt}}"},
        {"name": "HMACCOUNT", "value": "{{HMACCOUNT}}"},
        {"name": "acw_tc", "value": "{{acw_tc}}"},
        {"name": "authorized-token", "value": "{{authorized_token}}"},
        {"name": "multiple-tabs", "value": "{{multiple_tabs}}"},
        {"name": "Hm_lpvt_70c35e2a4eaa61e3234d43ac7a305148", "value": "{{Hm_lpvt}}"}
      ],
      "data": "",
      "mimeType": ""
    },
    "rule": {
      "success_asserts": [
        {"re": "200", "from": "status"}
      ],
      "failed_asserts": [],
      "extract_variables": [
        {"name": "todayCheckedIn", "re": "\"todayCheckedIn\":(true|false)", "from": "content"},
        {"name": "continuousDays", "re": "\"currentContinuousDays\":(\\d+)", "from": "content"},
        {"name": "totalDays", "re": "\"totalCheckInDays\":(\\d+)", "from": "content"},
        {"name": "totalEarned", "re": "\"totalEarned\":(\\d+)", "from": "content"},
        {"name": "tokenBalance", "re": "\"tokenBalance\":(\\d+)", "from": "content"},
        {"name": "todayReward", "re": "\"todayPotentialReward\":\\{[^}]*\"totalReward\":(\\d+)", "from": "content"},
        {"name": "__log__", "re": "\"message\":\"([^\"]+)\"", "from": "content"}
      ]
    }
  },
  {
    "comment": "每日签到",
    "request": {
      "method": "POST",
      "url": "https://sophnet.com/api/sys/checkin/do",
      "headers": [
        {"name": "Accept", "value": "application/json, text/plain, */*"},
        {"name": "Accept-Language", "value": "zh-CN,zh;q=0.9,en;q=0.8,en-GB;q=0.7,en-US;q=0.6,zh-TW;q=0.5"},
        {"name": "Content-Length", "value": "0"},
        {"name": "User-Agent", "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/150.0.0.0 Safari/537.36"},
        {"name": "Authorization", "value": "Bearer {{access_token}}"},
        {"name": "Connection", "value": "keep-alive"},
        {"name": "Origin", "value": "https://sophnet.com"},
        {"name": "Referer", "value": "https://sophnet.com/organization/welfare"},
        {"name": "Sec-Fetch-Dest", "value": "empty"},
        {"name": "Sec-Fetch-Mode", "value": "cors"},
        {"name": "Sec-Fetch-Site", "value": "same-origin"},
        {"name": "X-Requested-With", "value": "XMLHttpRequest"},
        {"name": "sec-ch-ua", "value": "\"Not;A=Brand\";v=\"8\", \"Chromium\";v=\"150\", \"Microsoft Edge\";v=\"150\""},
        {"name": "sec-ch-ua-mobile", "value": "?0"},
        {"name": "sec-ch-ua-platform", "value": "\"Windows\""}
      ],
      "cookies": [
        {"name": "_c_WBKFRo", "value": "{{_c_WBKFRo}}"},
        {"name": "Hm_lvt_70c35e2a4eaa61e3234d43ac7a305148", "value": "{{Hm_lvt}}"},
        {"name": "HMACCOUNT", "value": "{{HMACCOUNT}}"},
        {"name": "acw_tc", "value": "{{acw_tc}}"},
        {"name": "authorized-token", "value": "{{authorized_token}}"},
        {"name": "multiple-tabs", "value": "{{multiple_tabs}}"},
        {"name": "Hm_lpvt_70c35e2a4eaa61e3234d43ac7a305148", "value": "{{Hm_lpvt}}"}
      ],
      "data": "",
      "mimeType": ""
    },
    "rule": {
      "success_asserts": [
        {"re": "200", "from": "status"},
        {"re": "422", "from": "status"}
      ],
      "failed_asserts": [],
      "extract_variables": [
        {"name": "__log__", "re": "\"message\":\"([^\"]+)\"", "from": "content"}
      ]
    }
  },
  {
    "comment": "输出日志",
    "request": {
      "method": "POST",
      "url": "api://util/unicode",
      "headers": [],
      "cookies": [],
      "data": "html_unescape=false&content=SOPHNET: 用户{{user_name}}，{% if todayCheckedIn %}已签到{% else %}签到成功{% endif %}，连续{{continuousDays}}天（累计{{totalDays}}天），余额{{tokenBalance}}，今日获得{{todayReward}}。",
      "mimeType": "application/x-www-form-urlencoded"
    },
    "rule": {
      "success_asserts": [
        {"re": "200", "from": "status"},
        {"re": "\"状态\": \"200\"", "from": "content"}
      ],
      "failed_asserts": [],
      "extract_variables": [
        {"name": "__log__", "re": "\"转换后\": \"(.*)\"", "from": "content"}
      ]
    }
  }
]
