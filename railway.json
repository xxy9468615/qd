{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "dockerfilePath": "Dockerfile",
    "dockerfile": "Dockerfile"
  },
  "deploy": {
    "startCommand": "python run.py",
    "restartPolicyType": "ON_FAILURE",
    "numReplicas": 1,
    "healthcheckPath": "/",
    "healthcheckTimeout": 100,
    "volumes": [
      {
        "name": "qd-config",
        "mountPath": "/usr/src/app/config",
        "directory": "/"
      }
    ]
  }
}
