# Railway 环境变量 (Settings > Variables 里逐条添加, 不要提交进 git)
# 这些值通过 Railway 控制台配置, 本文件仅作清单参考

# --- 服务端口 (Railway 会注入 $PORT, 但 QD 默认读 PORT, 留空即可) ---
PORT=80

# --- 数据库: 使用 TiDB (MySQL 兼容) ---
DB_TYPE=mysql
JAWSDB_MARIA_URL=mysql://<用户名>:<密码>@<host>:4000/<数据库名>

# --- 任务执行: Batch 模式, 不依赖 Redis 队列 ---
WORKER_METHOD=Batch

# --- 关闭 Redis 连接失败警告 (Batch 模式不需要 Redis) ---
DISPLAY_IMPORT_WARNING=False

# --- 安全: 必须改成随机值 (Railway Variables 里用 Generate 生成) ---
COOKIE_SECRET=<随机40位字符串>
AES_KEY=<随机40位字符串>

# --- 时区 ---
TZ=Asia/Shanghai

# --- 第一个注册用户自动为管理员 ---
USER0ISADMIN=True

# --- 域名(邮箱重置密码用, 可留空或填 Railway 分配的域名) ---
DOMAIN=
